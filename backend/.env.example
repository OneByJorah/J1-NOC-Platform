# J1 NOC Platform backend environment template
# Copy to .env and fill in real values. Never commit .env to Git.

# --- Core ---
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg2://jnop:change-me@postgres:5432/jnop
REDIS_URL=redis://:change-me@redis:6379/0
BACKEND_CORS_ORIGINS=["http://localhost","http://127.0.0.1"]
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- AI / Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# --- Wazuh SIEM ---
WAZUH_API_URL=https://localhost:55000
WAZUH_USERNAME=wazuh
WAZUH_PASSWORD=wazuh
# Set to true for production once Wazuh has a valid/trusted certificate
WAZUH_VERIFY_SSL=false

# --- Optional cloud providers ---
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
