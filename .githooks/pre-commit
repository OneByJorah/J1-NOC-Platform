#!/usr/bin/env bash
# Pre-commit hook: block commits that look like they contain live secrets
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -euo pipefail

BLOCKED_PATTERNS=(
  'password=[^"\s]{8,}'
  'secret(_key)?=[^"\s]{8,}'
  'api[_-]?key=[^"\s]{8,}'
  'token=[^"\s]{8,}'
  'private[_-]?key'
  'BEGIN (RSA|OPENSSH|EC|DSA) PRIVATE KEY'
  'postgresql://[^:"]+:[^@]+@'
  'redis://:[^@]+@'
)

FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [[ -z "$FILES" ]]; then
  exit 0
fi

FOUND=0
for file in $FILES; do
  for pattern in "${BLOCKED_PATTERNS[@]}"; do
    if git diff --cached "$file" | grep -iE "$pattern" >/dev/null 2>&1; then
      echo "BLOCKED: potential secret matches pattern '$pattern' in $file"
      FOUND=1
    fi
  done
done

if [[ $FOUND -ne 0 ]]; then
  echo "Commit rejected. Move secrets to /etc/j1-noc-platform/.env.live (mode 600)."
  exit 1
fi
